---
/**
 * Digital business card landing page.
 * Served for all /histories/{id}/ URLs via nginx fallback (see nginx/default.conf).
 * The card ID is extracted from window.location.pathname client-side.
 *
 * Intentionally not indexed (ProfileLayout sets noindex, nofollow).
 * Not linked from any navigation — QR-code access only.
 */
import HistoriesCard from '../../components/HistoriesCard.astro';

const cardApiOrigin = import.meta.env.PUBLIC_CARD_API_ORIGIN ?? 'https://toji.homes';
---

<HistoriesCard cardApiOrigin={cardApiOrigin} />
