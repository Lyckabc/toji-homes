---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { neunexusCopy, seo, ui, MAILTO, serviceEndpoints, stackItems } from '../../../content/siteContent';
import { normalizePathname } from '../../../lib/i18n';

const locale = 'ko';
const t = ui[locale];
const copy = neunexusCopy[locale];
const meta = seo.neunexus[locale];
const pathname = normalizePathname(Astro.url.pathname);
---

<BaseLayout title={meta.title} description={meta.description} lang="ko" pathname={pathname}>
  <div class="flex flex-col min-h-screen">
    <Header locale={locale} />

    <main class="flex-1">
      <article class="max-w-3xl mx-auto px-6 py-16 sm:py-20">
        <header class="mb-12">
          <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-gray-900 dark:text-gray-100 mb-2">neunexus</h1>
          <p class="text-lg text-gray-500 dark:text-gray-400">{copy.tagline}</p>
          <p class="text-sm text-gray-400 dark:text-gray-500 mt-2">{copy.oneLiner}</p>
          <a
            href={copy.repo}
            class="inline-block mt-4 text-sm font-semibold text-blue-600 dark:text-blue-400 hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t.projects.repository} ↗
          </a>
        </header>

        <section class="mb-10">
          <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-3">{t.projects.deployment}</h2>
          <ul class="list-disc pl-5 space-y-2 text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
            {copy.deployment.map((line) => (
              <li>{line}</li>
            ))}
          </ul>
        </section>

        <section class="mb-10">
          <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-3">{t.projects.definitions}</h2>
          <ul class="list-disc pl-5 space-y-2 text-gray-600 dark:text-gray-400 text-sm">
            {copy.definitions.map((line) => (
              <li>{line}</li>
            ))}
          </ul>
        </section>

        <section class="mb-10">
          <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-3">{t.projects.selectionGuide}</h2>
          <ul class="list-disc pl-5 space-y-2 text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
            {copy.selection.map((line) => (
              <li>{line}</li>
            ))}
          </ul>
        </section>

        <section class="mb-10">
          <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-3">{t.projects.stackLinks}</h2>
          <ul class="space-y-2">
            {copy.stackLinks.map((s) => (
              <li>
                <a href={s.href} class="text-sm text-blue-600 dark:text-blue-400 hover:underline font-mono" target="_blank" rel="noopener noreferrer">
                  {s.label} ↗
                </a>
              </li>
            ))}
          </ul>
        </section>

        <section class="mb-14">
          <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-4">{t.projects.deployedServices}</h2>
          <ul class="space-y-2">
            {copy.services.map((s) => (
              <li>
                <a href={s.href} class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" target="_blank" rel="noopener noreferrer">
                  {s.label} ↗
                </a>
              </li>
            ))}
          </ul>
        </section>
      </article>

      <section id="services" class="py-16 border-t border-gray-100 dark:border-gray-800">
        <div class="max-w-5xl mx-auto px-6">
          <h2 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-gray-100 mb-2">{t.home.servicesTitle}</h2>
          <p class="text-sm text-gray-400 dark:text-gray-500 mb-10">{t.home.servicesLead}</p>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {serviceEndpoints.map((service) => (
              <a
                href={service.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex flex-col gap-1.5 p-5 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 hover:border-blue-300 dark:hover:border-blue-700 hover:shadow-sm transition-all"
              >
                <div class="flex items-center justify-between">
                  <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100">{service.name[locale]}</h3>
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 14 14"
                    fill="none"
                    class="text-gray-300 dark:text-gray-600 group-hover:text-blue-500 transition-colors"
                    aria-hidden="true"
                  >
                    <path
                      d="M2 12L12 2M12 2H6M12 2V8"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </div>
                <p class="text-xs text-gray-400 dark:text-gray-500 leading-relaxed">{service.description[locale]}</p>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section id="stack" class="py-16 border-t border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900/50">
        <div class="max-w-5xl mx-auto px-6">
          <h2 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-gray-100 mb-2">{t.home.stackTitle}</h2>
          <p class="text-sm text-gray-400 dark:text-gray-500 mb-10">{t.home.stackLead}</p>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
            <div class="space-y-4 text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
              <p>{t.home.stackBody1}</p>
              <p>{t.home.stackBody2}</p>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
              {stackItems.map((item) => (
                <div class="p-3 rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900">
                  <p class="text-xs font-semibold text-gray-900 dark:text-gray-100 mb-0.5">{item.label}</p>
                  <p class="text-xs text-gray-400 dark:text-gray-500">{item.desc[locale]}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="border-t border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-950 pt-10 pb-16">
        <div class="max-w-5xl mx-auto px-6">
          <a
            href={MAILTO}
            class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors"
          >
            {t.about.contactCta}
          </a>
        </div>
      </section>
    </main>

    <Footer locale={locale} />
  </div>
</BaseLayout>
