---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { homeCopy, seo, ui, prefixPath, MAILTO } from '../../content/siteContent';
import { normalizePathname } from '../../lib/i18n';

const locale = 'ko';
const t = ui[locale];
const copy = homeCopy[locale];
const meta = seo.home[locale];
const pathname = normalizePathname(Astro.url.pathname);
const roadmapHref = `${prefixPath('/about', locale)}#roadmap`;
---

<BaseLayout title={meta.title} description={meta.description} lang="ko" pathname={pathname}>
  <div class="flex flex-col min-h-screen">
    <Header locale={locale} />

    <main class="flex-1">
      <section class="py-20 sm:py-28">
        <div class="max-w-5xl mx-auto px-6 text-center">
          <span
            class="inline-block px-3 py-1 mb-6 text-xs font-semibold tracking-wide text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-950 border border-blue-200 dark:border-blue-800 rounded-full"
          >
            {t.home.badge}
          </span>
          <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight text-gray-900 dark:text-gray-100 mb-5 leading-tight">
            {copy.headline}
          </h1>
          <p class="text-base sm:text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
            {copy.subcopy}
          </p>
          <div class="flex flex-wrap gap-3 justify-center">
            <a
              href={roadmapHref}
              class="px-5 py-2.5 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors"
            >
              {t.cta.exploreServices}
            </a>
            <a
              href={MAILTO}
              class="px-5 py-2.5 rounded-lg border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 text-sm font-semibold transition-colors"
            >
              {t.cta.contact}
            </a>
          </div>
        </div>
      </section>

      <section class="py-14 border-t border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900/40">
        <div class="max-w-5xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
          <div>
            <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-3">{t.home.aboutPreviewTitle}</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed mb-6">{copy.aboutSummary}</p>
            <a
              href={prefixPath('/about', locale)}
              class="inline-flex text-sm font-semibold text-blue-600 dark:text-blue-400 hover:underline"
            >
              {t.cta.readAbout} →
            </a>
          </div>
          <div class="flex justify-center md:justify-end">
            <img
              src="/toji_only_logo_rev4.png"
              alt="TOJI"
              width="200"
              height="80"
              class="max-h-24 w-auto object-contain dark:invert opacity-90"
              loading="lazy"
            />
          </div>
        </div>
      </section>

      <section class="py-16 border-t border-gray-100 dark:border-gray-800">
        <div class="max-w-5xl mx-auto px-6">
          <h2 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-gray-100 mb-8">{t.home.projectsTitle}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {copy.projects.map((project) => (
              <a
                href={prefixPath(`/projects/${project.slug}`, locale)}
                class="group flex flex-col gap-2 p-6 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 hover:border-blue-300 dark:hover:border-blue-700 hover:shadow-sm transition-all"
              >
                <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">{project.title}</h3>
                <p class="text-xs font-medium uppercase tracking-wide text-blue-600 dark:text-blue-400">{project.description}</p>
                <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{project.summary}</p>
                <span class="text-sm font-semibold text-blue-600 dark:text-blue-400 mt-2 group-hover:underline">
                  {t.cta.viewProject} →
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    </main>

    <Footer locale={locale} />
  </div>
</BaseLayout>
