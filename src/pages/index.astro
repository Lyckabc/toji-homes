---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    name: 'Forgejo',
    description: 'Self-hosted Git service. Source code, CI/CD, and container registry.',
    href: 'https://git.toji.homes',
  },
  {
    name: 'Vikunja',
    description: 'Task and project management. Kanban boards and to-do lists.',
    href: 'https://task.toji.homes',
  },
  {
    name: 'Grafana',
    description: 'Observability stack. Metrics, logs, and traces in one place.',
    href: 'https://grafana.toji.homes',
  },
  {
    name: 'Artifact Registry',
    description: 'Universal artifact repository for Docker images and packages.',
    href: 'https://artifacts.toji.homes',
  },
  {
    name: 'ZITADEL',
    description: 'Identity and access management. SSO and OIDC for all services.',
    href: 'https://auth.toji.homes',
  },
  {
    name: 'Vault',
    description: 'Secrets management. Secure storage for credentials and certificates.',
    href: 'https://vault.toji.homes',
  },
];

const stack = [
  { label: 'OpenStack',  desc: 'Dalmatian · kolla-ansible' },
  { label: 'Kubernetes', desc: 'v1.35 · Calico CNI' },
  { label: 'Traefik',    desc: 'Ingress · TLS termination' },
  { label: 'Cinder CSI', desc: 'SSD + HDD persistent volumes' },
  { label: 'Vault',      desc: 'Secrets · TOTP · AppRole' },
  { label: 'OpenTofu',   desc: 'Infrastructure as Code' },
];
---

<BaseLayout
  title="toji.homes — Homelab Platform"
  description="A self-hosted homelab platform on OpenStack and Kubernetes. Git, CI/CD, monitoring, secrets — all under one roof."
>
  <div class="flex flex-col min-h-screen">
    <Header />

    <main class="flex-1">

      <!-- ── Hero ───────────────────────────────────── -->
      <section class="py-24 sm:py-32">
        <div class="max-w-5xl mx-auto px-6 text-center">
          <span class="inline-block px-3 py-1 mb-6 text-xs font-semibold tracking-wide text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-950 border border-blue-200 dark:border-blue-800 rounded-full">
            Self-hosted · On-premises
          </span>
          <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight text-gray-900 dark:text-gray-100 mb-5">
            Your homelab,<br class="hidden sm:block" /> fully orchestrated.
          </h1>
          <p class="text-lg text-gray-500 dark:text-gray-400 max-w-xl mx-auto mb-10 leading-relaxed">
            toji.homes runs on a private OpenStack cluster and Kubernetes.
            Git, tasks, monitoring, secrets — all under one roof.
          </p>
          <div class="flex flex-wrap gap-3 justify-center">
            <a
              href="#services"
              class="px-5 py-2.5 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors"
            >
              Explore Services
            </a>
            <a
              href="https://git.toji.homes"
              target="_blank"
              rel="noopener noreferrer"
              class="px-5 py-2.5 rounded-lg border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 text-sm font-semibold transition-colors"
            >
              Open Forgejo ↗
            </a>
          </div>
        </div>
      </section>

      <!-- ── Services ───────────────────────────────── -->
      <section id="services" class="py-16 border-t border-gray-100 dark:border-gray-800">
        <div class="max-w-5xl mx-auto px-6">
          <h2 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-gray-100 mb-2">Services</h2>
          <p class="text-sm text-gray-400 dark:text-gray-500 mb-10">Everything running on the cluster, accessible via SSO.</p>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {services.map(service => (
              <a
                href={service.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex flex-col gap-1.5 p-5 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 hover:border-blue-300 dark:hover:border-blue-700 hover:shadow-sm transition-all"
              >
                <div class="flex items-center justify-between">
                  <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100">{service.name}</h3>
                  <svg
                    width="14" height="14" viewBox="0 0 14 14" fill="none"
                    class="text-gray-300 dark:text-gray-600 group-hover:text-blue-500 transition-colors"
                    aria-hidden="true"
                  >
                    <path d="M2 12L12 2M12 2H6M12 2V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <p class="text-xs text-gray-400 dark:text-gray-500 leading-relaxed">{service.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- ── About / Stack ──────────────────────────── -->
      <section id="about" class="py-16 border-t border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900/50">
        <div class="max-w-5xl mx-auto px-6">
          <h2 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-gray-100 mb-2">About</h2>
          <p class="text-sm text-gray-400 dark:text-gray-500 mb-10">Built on open-source infrastructure, managed as code.</p>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
            <!-- 텍스트 -->
            <div class="space-y-4 text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
              <p>
                toji.homes is a fully self-hosted homelab platform.
                Every service runs on a two-node Kubernetes cluster backed
                by OpenStack Dalmatian for compute, network, and storage.
              </p>
              <p>
                Infrastructure is declared with OpenTofu, secrets live in
                Vault, and all access is controlled by ZITADEL with OIDC
                single sign-on.
              </p>
            </div>

            <!-- Stack 그리드 -->
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
              {stack.map(item => (
                <div class="p-3 rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900">
                  <p class="text-xs font-semibold text-gray-900 dark:text-gray-100 mb-0.5">{item.label}</p>
                  <p class="text-xs text-gray-400 dark:text-gray-500">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

    </main>

    <Footer />
  </div>
</BaseLayout>
