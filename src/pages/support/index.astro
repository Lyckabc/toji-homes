---
import SupportLayout from '../../layouts/SupportLayout.astro';
import { getSupportStrings } from '../../lib/support/i18n';

const locale = 'en' as const;
const t = getSupportStrings(locale);

const faq = [
  {
    q: 'How do I get help quickly?',
    a: 'Use the floating help button at the bottom-right of any page on toji.homes. Type your question and we will suggest relevant answers, or open a ticket.',
  },
  {
    q: 'How do I check the status of my ticket?',
    a: 'Use the magic link sent to your email after submitting a ticket. You can also re-request the link from the sign-in page.',
  },
  {
    q: 'How long does support take to respond?',
    a: 'We aim to respond within one business day. Urgent issues are prioritized.',
  },
];
---

<SupportLayout
  title={`${t.landing.title} — TOJI`}
  description={t.landing.lead}
  lang={locale}
>
  <article class="max-w-3xl mx-auto px-6 py-16 sm:py-20">
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-gray-900 dark:text-gray-100 mb-3">
      {t.landing.title}
    </h1>
    <p class="text-base text-gray-500 dark:text-gray-400 mb-10">{t.landing.lead}</p>

    <div class="flex flex-wrap gap-3 mb-12">
      <a
        href="/support/tickets/new/"
        class="px-5 py-2.5 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold"
      >
        {t.landing.openTicket}
      </a>
    </div>

    <section class="border-t border-gray-100 dark:border-gray-800 pt-8">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-5">{t.landing.faqTitle}</h2>
      <ul class="flex flex-col gap-4">
        {faq.map((item) => (
          <li class="rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-4">
            <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-2">{item.q}</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{item.a}</p>
          </li>
        ))}
      </ul>
    </section>
  </article>
</SupportLayout>
