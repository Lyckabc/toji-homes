---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AiPragmaPage from '../../components/projects/AiPragmaPage.astro';
import { seo } from '../../content/siteContent';
import { normalizePathname } from '../../lib/i18n';

const locale = 'en';
const meta = seo.aiPragma[locale];
const pathname = normalizePathname(Astro.url.pathname);
---

<BaseLayout title={meta.title} description={meta.description} lang="en" pathname={pathname}>
  <div class="flex flex-col min-h-screen">
    <Header locale={locale} />

    <main class="flex-1">
      <AiPragmaPage locale={locale} />
    </main>

    <Footer locale={locale} />
  </div>
</BaseLayout>
