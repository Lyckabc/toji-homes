---
import type { Locale } from '../content/siteContent';
import { ui, prefixPath, GITHUB_ORG_URL, MAILTO } from '../content/siteContent';
import { normalizePathname, switchLocalePath } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale];
const p = normalizePathname(Astro.url.pathname);
const path = Astro.url.pathname;

const home = prefixPath('/', locale);
const about = prefixPath('/about', locale);
const gopedia = prefixPath('/projects/gopedia', locale);
const neunexus = prefixPath('/projects/neunexus', locale);

const hrefKo = switchLocalePath(path, 'ko');
const hrefEn = switchLocalePath(path, 'en');

const activeHome = p === '/' || p === '/ko';
const activeAbout = p === '/about' || p === '/ko/about';
const activeGopedia = p === '/projects/gopedia' || p === '/ko/projects/gopedia';
const activeNeunexus = p === '/projects/neunexus' || p === '/ko/projects/neunexus';
const activeProjects = activeGopedia || activeNeunexus;
---

<header class="sticky top-0 z-50 bg-white/90 dark:bg-gray-950/90 backdrop-blur border-b border-gray-200 dark:border-gray-800">
  <div class="max-w-5xl mx-auto px-6 min-h-14 flex flex-wrap items-center gap-y-2 gap-x-3 py-2 sm:py-0 sm:h-14">
    <a
      href={home}
      class="flex items-center gap-2.5 font-semibold text-gray-900 dark:text-gray-100 hover:opacity-80 transition-opacity shrink-0"
    >
      <img
        src="/toji_only_logo_rev4.png"
        alt="TOJI"
        width="120"
        height="40"
        class="h-8 w-auto object-contain dark:invert"
        loading="eager"
      />
      <span class="text-sm tracking-tight">TOJI</span>
    </a>

    <nav class="flex flex-wrap items-center gap-1 sm:gap-0.5 ml-auto" aria-label="Main navigation">
      <a
        href={home}
        class:list={[
          'px-2.5 sm:px-3 py-1.5 rounded-md text-sm font-medium transition-colors',
          activeHome
            ? 'text-gray-900 dark:text-gray-100 bg-gray-100 dark:bg-gray-800'
            : 'text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-800',
        ]}
      >
        {t.nav.home}
      </a>
      <a
        href={about}
        class:list={[
          'px-2.5 sm:px-3 py-1.5 rounded-md text-sm font-medium transition-colors',
          activeAbout
            ? 'text-gray-900 dark:text-gray-100 bg-gray-100 dark:bg-gray-800'
            : 'text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-800',
        ]}
      >
        {t.nav.about}
      </a>

      <details
        class:list={[
          'relative group',
          '[&_summary::-webkit-details-marker]:hidden [&_summary::marker]:content-none',
        ]}
      >
        <summary
          class:list={[
            'px-2.5 sm:px-3 py-1.5 rounded-md text-sm font-medium cursor-pointer list-none transition-colors',
            activeProjects
              ? 'text-gray-900 dark:text-gray-100 bg-gray-100 dark:bg-gray-800'
              : 'text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-800',
          ]}
        >
          {t.nav.projects}
        </summary>
        <div class="absolute left-0 top-full z-50 pt-1 min-w-[11rem]">
          <ul
            class="rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 py-1 shadow-lg"
            role="list"
          >
            <li>
              <a
                href={gopedia}
                class:list={[
                  'block px-3 py-2 text-sm transition-colors',
                  activeGopedia
                    ? 'bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-gray-100 font-medium'
                    : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-900',
                ]}
              >
                {t.nav.gopedia}
              </a>
            </li>
            <li>
              <a
                href={neunexus}
                class:list={[
                  'block px-3 py-2 text-sm transition-colors',
                  activeNeunexus
                    ? 'bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-gray-100 font-medium'
                    : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-900',
                ]}
              >
                {t.nav.neunexus}
              </a>
            </li>
          </ul>
        </div>
      </details>

      <div class="hidden sm:block w-px h-5 bg-gray-200 dark:bg-gray-700 mx-0.5" aria-hidden="true"></div>

      <a
        href={GITHUB_ORG_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 px-2 py-1.5 rounded-md text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
      >
        {t.nav.git}
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true" class="opacity-40">
          <path d="M1 9L9 1M9 1H4M9 1V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
      <a
        href={MAILTO}
        class="inline-flex items-center gap-1 px-2 py-1.5 rounded-md text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
      >
        {t.nav.enquiry}
      </a>

      <div class="hidden sm:block w-px h-5 bg-gray-200 dark:bg-gray-700 mx-0.5" aria-hidden="true"></div>

      <nav class="flex items-center gap-2 text-sm" aria-label="Language">
        <a
          href={hrefKo}
          class:list={[
            'font-medium transition-colors',
            locale === 'ko'
              ? 'text-blue-600 dark:text-blue-400'
              : 'text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300',
          ]}
          hreflang="ko"
          lang="ko"
        >
          {t.footer.langKo}
        </a>
        <span class="text-gray-300 dark:text-gray-600" aria-hidden="true">|</span>
        <a
          href={hrefEn}
          class:list={[
            'font-medium transition-colors',
            locale === 'en'
              ? 'text-blue-600 dark:text-blue-400'
              : 'text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300',
          ]}
          hreflang="en"
          lang="en"
        >
          {t.footer.langEn}
        </a>
      </nav>

      <div class="hidden sm:block w-px h-5 bg-gray-200 dark:bg-gray-700 mx-0.5" aria-hidden="true"></div>

      <button
        type="button"
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="p-1.5 rounded-md text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden dark:block">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
        </svg>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="block dark:hidden">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('theme-toggle');

  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (!localStorage.getItem('theme')) {
      document.documentElement.classList.toggle('dark', e.matches);
    }
  });

  document.querySelectorAll('header details').forEach((d) => {
    d.addEventListener('click', (e) => {
      const t = e.target;
      if (t instanceof HTMLAnchorElement) (d as HTMLDetailsElement).open = false;
    });
  });
</script>
