  <div class="gp-wrap gp-nav-row">
    <div class="gp-brand">
      <svg class="gp-brand-mark" viewBox="0 0 32 32" fill="none">
        <path d="M16 3 L16 29" stroke="var(--moss)" stroke-width="1.2"/>
        <path d="M16 9 Q9 12 7 19 M16 9 Q23 12 25 19 M16 16 Q11 19 9 25 M16 16 Q21 19 23 25" stroke="var(--moss)" stroke-width="0.9" fill="none"/>
        <circle cx="16" cy="3" r="2" fill="var(--moss)"/>
        <circle cx="7" cy="19" r="1.4" fill="var(--leaf)"/>
        <circle cx="25" cy="19" r="1.4" fill="var(--leaf)"/>
