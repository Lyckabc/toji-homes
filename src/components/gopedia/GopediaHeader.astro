        <circle cx="23" cy="25" r="1.2" fill="var(--leaf)"/>
      </svg>
      <span>Gopedia</span>
    </div>
    <ul class="gp-nav-links">
      <li><a href="#values"><span data-ko-block>철학</span><span data-en-block>Philosophy</span></a></li>
      <li><a href="#scenarios"><span data-ko-block>시나리오</span><span data-en-block>Scenarios</span></a></li>
      <li><a href="#quality"><span data-ko-block>품질</span><span data-en-block>Quality</span></a></li>
      <li><a href="#roadmap"><span data-ko-block>로드맵</span><span data-en-block>Roadmap</span></a></li>
    </ul>
    <div class="gp-nav-controls">
      <!-- Theme switcher -->
      <div class="gp-theme-switch" role="group" aria-label="Theme">
        <button class="gp-theme-dot active" data-theme="moss" title="Moss" style="--dot:#3a5a3a;--dot-bg:#f4f1ea"><span></span></button>
        <button class="gp-theme-dot" data-theme="twilight" title="Twilight" style="--dot:#a8c98a;--dot-bg:#1a1f1a"><span></span></button>
        <button class="gp-theme-dot" data-theme="parchment" title="Parchment" style="--dot:#6b5a2a;--dot-bg:#f7f1e1"><span></span></button>
        <button class="gp-theme-dot" data-theme="ash" title="Ash" style="--dot:#4a5a4a;--dot-bg:#ebe9e4"><span></span></button>
