---
const year = new Date().getFullYear();

const links = [
  { label: 'Forgejo',  href: 'https://git.toji.homes' },
  { label: 'Grafana',  href: 'https://grafana.toji.homes' },
  { label: 'Vault',    href: 'https://vault.toji.homes' },
];
---

<footer class="border-t border-gray-200 dark:border-gray-800">
  <div class="max-w-5xl mx-auto px-6 py-6 flex flex-wrap items-center justify-between gap-4">
    <span class="text-sm text-gray-400 dark:text-gray-500">
      © {year} toji.homes
    </span>
    <nav class="flex gap-5" aria-label="Footer navigation">
      {links.map(link => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</footer>
