---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Gopedia — 세계수에서 자라는 지식',
  description = '엔터프라이즈 지식 그래프 플랫폼. 온톨로지 + RAG 기반 데이터 관리.',
} = Astro.props;
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@300;400;500;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" />
</head>
<body data-lang="ko">
  <slot />
</body>
</html>

<style is:global>
  /* ── Gopedia design tokens ── */
  :root {
    --paper: #f4f1ea; --paper-2: #ede8db; --paper-3: #e3dccb;
    --ink: #1f2418;   --ink-2:  #3a4234;
    --moss: #3a5a3a;  --moss-2: #5a7a4a; --leaf: #7a9a4a;
    --bark: #6b4a2a;  --bark-2: #8a6a3a;
    --bloom: #c45a3a; --gold: #b8923a;
    --rule:  rgba(31,36,24,.18); --rule-2: rgba(31,36,24,.10);
    --serif:   "Noto Serif KR","Cormorant Garamond",serif;
    --display: "Cormorant Garamond","Noto Serif KR",serif;
    --sans:    "Noto Sans KR",system-ui,sans-serif;
    --mono:    "JetBrains Mono",ui-monospace,monospace;
  }

  /* ── Base ── */
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--serif);
    font-weight: 400;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    overflow-x: hidden;
    transition: background .5s ease, color .5s ease;
  }

  /* ── Paper-grain texture ── */
  body::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(rgba(60,50,30,.04) 1px, transparent 1px),
      radial-gradient(rgba(60,50,30,.025) 1px, transparent 1px);
    background-size: 3px 3px, 7px 7px;
    background-position: 0 0, 1px 2px;
    mix-blend-mode: multiply;
    z-index: 1;
  }

  /* ── Text selection ── */
  ::selection { background: var(--moss); color: var(--paper); }

  /* ── Bilingual toggle ── */
  [data-en-block], [data-ko-block] { display: block; }
  body[data-lang="ko"] [data-en-block] { display: none; }
  body[data-lang="en"] [data-ko-block] { display: none; }

  /* ── Inline bilingual spans ── */
  span[data-en-block], span[data-ko-block] { display: inline; }
  body[data-lang="ko"] span[data-en-block] { display: none; }
  body[data-lang="en"] span[data-ko-block] { display: none; }

  a { color: inherit; }

  /* ── .wrap container ── */
  .wrap { max-width: 1280px; margin: 0 auto; padding: 0 48px; position: relative; z-index: 2; }
  @media (max-width: 720px) { .wrap { padding: 0 24px; } }

  /* ─── NAV ─────────────────────────────────────── */
  nav.top {
    position: sticky; top: 0; z-index: 50;
    backdrop-filter: blur(8px);
    background: rgba(244,241,234,.72);
    border-bottom: 1px solid var(--rule-2);
  }
  nav.top .row {
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--display);
    font-size: 15px; font-weight: 500;
    letter-spacing: .03em;
  }
  .brand-mark {
    width: 20px; height: 20px;
  }
  nav.top ul {
    display: flex; gap: 28px; list-style: none; padding: 0; margin: 0;
    font-family: var(--sans); font-size: 13px; color: var(--ink-2);
    font-weight: 400; letter-spacing: .04em;
  }
  nav.top ul a { text-decoration: none; }
  nav.top ul a:hover { color: var(--moss); }
  .lang-toggle {
    display: inline-flex; gap: 0;
    border: 1px solid var(--rule);
    border-radius: 999px;
    overflow: hidden;
    font-family: var(--sans);
    font-size: 11px; font-weight: 500;
    letter-spacing: .08em;
  }
  .lang-toggle button {
    background: transparent; border: 0; padding: 6px 12px;
    color: var(--ink-2);
    cursor: pointer;
  }
  .lang-toggle button.active {
    background: var(--ink);
    color: var(--paper);
  }
  @media (max-width: 720px) {
    nav.top ul { display: none; }
  }

  /* ─── HERO ──────────────────────────────────── */
  .hero {
    position: relative;
    padding: 80px 0 160px;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 60px;
    align-items: center;
  }
  @media (max-width: 980px) {
    .hero-grid { grid-template-columns: 1fr; }
  }

  /* ─── SECTION CHROME ───────────────────────── */
  section { position: relative; padding: 100px 0; }
  .section-head {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 60px;
    margin-bottom: 64px;
    align-items: end;
  }
  @media (max-width: 880px) {
    .section-head { grid-template-columns: 1fr; gap: 24px; }
  }
  .section-num {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .3em;
    color: var(--moss);
    text-transform: uppercase;
  }
  .section-title {
    font-family: var(--display);
    font-weight: 400;
    font-size: clamp(34px, 3.8vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 12px 0 0;
  }
  .section-title em { font-style: italic; color: var(--moss); }
  .section-sub {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-2);
    max-width: 560px;
  }
  .rule {
    height: 1px; background: var(--rule); margin: 0;
  }

  /* ─── CORE VALUES (4 cards, botanical) ─────── */
  .values {
    background: var(--paper-2);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .value-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-left: 1px solid var(--rule);
  }
  @media (max-width: 980px) {
    .value-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .value-grid { grid-template-columns: 1fr; }
  }
  .value {
    border-right: 1px solid var(--rule);
    border-top: 1px solid var(--rule);
    padding: 36px 28px 40px;
    background: var(--paper-2);
    position: relative;
    transition: background .3s ease;
  }
  .value:hover { background: var(--paper); }
  .value-glyph {
    width: 40px; height: 40px;
    margin-bottom: 20px;
    color: var(--moss);
  }
  .value-name {
    font-family: var(--display);
    font-style: italic;
    font-size: 14px;
    color: var(--moss);
    letter-spacing: .04em;
    margin-bottom: 4px;
  }
  .value-title {
    font-family: var(--display);
    font-size: 28px;
    font-weight: 500;
    margin: 0 0 14px;
    line-height: 1.15;
  }
  .value-body {
    font-family: var(--serif);
    font-size: 14.5px;
    line-height: 1.7;
    color: var(--ink-2);
  }

  /* ─── SCENARIOS (story cards) ─────────────── */
  .scenarios { background: var(--paper); }
  .scenario {
    display: grid;
    grid-template-columns: 96px 1fr 1.1fr;
    gap: 48px;
    padding: 56px 0;
    border-top: 1px solid var(--rule);
    align-items: start;
  }
  .scenario:last-child { border-bottom: 1px solid var(--rule); }
  @media (max-width: 880px) {
    .scenario { grid-template-columns: 1fr; gap: 24px; }
  }
  .scen-num {
    font-family: var(--display);
    font-style: italic;
    font-size: 56px;
    color: var(--moss);
    line-height: 1;
  }
  .scen-text h3 {
    font-family: var(--display);
    font-weight: 500;
    font-size: 30px;
    margin: 0 0 8px;
    line-height: 1.15;
  }
  .scen-role {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: var(--moss);
    margin-bottom: 16px;
  }
  .scen-body {
    font-family: var(--serif);
    font-size: 15.5px;
    line-height: 1.75;
    color: var(--ink-2);
  }
  .scen-mock {
    background: var(--paper-2);
    border: 1px solid var(--rule);
    padding: 22px;
    border-radius: 2px;
    font-family: var(--mono);
    font-size: 12.5px;
    line-height: 1.65;
    color: var(--ink-2);
    position: relative;
  }
  .scen-mock .q { color: var(--moss); }
  .scen-mock .a { color: var(--ink); }
  .scen-mock .meta { color: var(--bark); font-size: 11px; }
  .scen-mock .src {
    display: inline-block;
    border: 1px solid var(--rule);
    padding: 2px 8px;
    margin-right: 6px;
    margin-top: 4px;
    border-radius: 999px;
    font-size: 10.5px;
    color: var(--moss);
  }
  .scen-mock .label {
    position: absolute; top: -10px; left: 16px;
    background: var(--paper);
    padding: 0 8px;
    font-family: var(--display);
    font-style: italic;
    font-size: 12px;
    color: var(--moss);
  }

  /* ─── IR CHART ───────────────────────────── */
  .quality {
    background: var(--paper-2);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .ir-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
  }
  @media (max-width: 880px) {
    .ir-grid { grid-template-columns: 1fr; }
  }
  .ir-chart {
    background: var(--paper);
    border: 1px solid var(--rule);
    padding: 32px;
    position: relative;
  }
  .ir-chart-title {
    font-family: var(--display);
    font-style: italic;
    font-size: 16px;
    color: var(--moss);
    margin-bottom: 20px;
    display: flex; justify-content: space-between; align-items: baseline;
  }
  .ir-chart-title .scale {
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--ink-2);
    font-style: normal;
    letter-spacing: .1em;
  }
  .ir-bars {
    display: grid;
    gap: 20px;
  }
  .ir-bar {
    display: grid;
    grid-template-columns: 130px 1fr 56px;
    gap: 14px;
    align-items: center;
  }
  .ir-bar .name {
    font-family: var(--sans);
    font-size: 12.5px;
    color: var(--ink-2);
  }
  .ir-bar .name small {
    display: block;
    font-size: 10px;
    letter-spacing: .12em;
    color: var(--bark);
    text-transform: uppercase;
  }
  .ir-track {
    height: 22px;
    background: repeating-linear-gradient(90deg, transparent 0, transparent 19px, var(--rule-2) 19px, var(--rule-2) 20px);
    border-bottom: 1px solid var(--rule);
    position: relative;
  }
  .ir-fill {
    position: absolute;
    top: 0; left: 0; bottom: 1px;
    background: var(--moss);
    width: 0;
    transition: width 1.4s cubic-bezier(.2,.7,.2,1);
  }
  .ir-fill.alt { background: var(--bark-2); }
  .ir-bar .v {
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--moss);
    text-align: right;
  }
  .ir-bar .v.alt { color: var(--bark-2); }
  .ir-legend {
    display: flex; gap: 18px; margin-top: 18px;
    font-family: var(--sans); font-size: 11px;
    color: var(--ink-2);
  }
  .ir-legend i {
    width: 10px; height: 10px; display: inline-block;
    margin-right: 6px; vertical-align: middle;
  }
  .ir-copy h3 {
    font-family: var(--display);
    font-size: 36px;
    font-weight: 500;
    line-height: 1.1;
    margin: 0 0 16px;
  }
  .ir-copy h3 em { font-style: italic; color: var(--moss); }
  .ir-copy p {
    font-family: var(--serif);
    font-size: 16px; line-height: 1.7;
    color: var(--ink-2);
  }
  .ir-foot {
    margin-top: 18px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--bark);
    letter-spacing: .04em;
  }

  /* ─── ROADMAP ──────────────────────────── */
  .roadmap { background: var(--paper); }
  .road-track {
    position: relative;
    margin-top: 24px;
    padding: 60px 0 40px;
  }
  .road-line {
    position: absolute;
    top: 50%; left: 0; right: 0;
    height: 1px;
    background: var(--rule);
    transform: translateY(-50%);
  }
  .road-grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  @media (max-width: 760px) {
    .road-grid { grid-template-columns: 1fr; gap: 24px; }
    .road-line { display: none; }
  }
  .road-step {
    background: var(--paper);
    padding: 24px;
    border: 1px solid var(--rule);
    position: relative;
  }
  .road-step::before {
    content: "";
    position: absolute; top: -7px; left: 24px;
    width: 12px; height: 12px;
    background: var(--paper);
    border: 1px solid var(--moss);
    border-radius: 50%;
  }
  .road-step.cur::before { background: var(--moss); }
  .road-step.future::before { border-style: dashed; }
  .road-stage {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: .25em;
    color: var(--moss);
    text-transform: uppercase;
  }
  .road-step h4 {
    font-family: var(--display);
    font-weight: 500;
    font-size: 26px;
    margin: 8px 0 10px;
    line-height: 1.15;
  }
  .road-step h4 em { font-style: italic; color: var(--moss); }
  .road-step p {
    font-family: var(--serif);
    font-size: 14px; line-height: 1.7; color: var(--ink-2);
    margin: 0 0 14px;
  }
  .road-tags {
    display: flex; gap: 6px; flex-wrap: wrap;
  }
  .road-tag {
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--bark-2);
    border: 1px solid var(--rule);
    padding: 3px 8px;
    border-radius: 999px;
  }

  /* ─── FOOTER ──────────────────────────── */
  footer {
    background: var(--ink);
    color: var(--paper);
    padding: 80px 0 40px;
    margin-top: 0;
  }
  .foot-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 40px;
  }
  @media (max-width: 760px) {
    .foot-grid { grid-template-columns: 1fr; }
  }
  footer h5 {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: rgba(244,241,234,.5);
    font-weight: 500;
    margin: 0 0 16px;
  }
  footer ul {
    list-style: none; padding: 0; margin: 0;
    font-family: var(--serif); font-size: 15px; line-height: 1.9;
    color: rgba(244,241,234,.85);
  }
  footer ul a { text-decoration: none; }
  footer ul a:hover { color: #c5d99a; }
  .foot-tag {
    font-family: var(--display);
    font-style: italic;
    font-size: 15px;
    line-height: 1.5;
    color: rgba(244,241,234,.85);
    max-width: 360px;
    margin-top: 12px;
  }
  .foot-bot {
    margin-top: 60px;
    padding-top: 24px;
    border-top: 1px solid rgba(244,241,234,.12);
    display: flex; justify-content: space-between; align-items: center;
    font-family: var(--mono);
    font-size: 11px;
    color: rgba(244,241,234,.5);
    letter-spacing: .08em;
  }
</style>
